# ─────────────────────────────────────────
# Terafab Server Environment Variables
# Copy this to .env and fill in your values
# ─────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=production

# CORS - frontend origin (多个域名可逗号分隔)
FRONTEND_URL=https://terafab.top

# Admin password (change this!)
ADMIN_PASSWORD=terafab_admin_2025

# Database path (relative to server/)
DB_PATH=./data/terafab.db

# Game config
LIKES_TO_LAUNCH=10000

# Wallet address for USDT donations (BNB chain)
WALLET_ADDRESS=0x0000000000000000000000000000000000000000

# BscScan API key (for tx verification in Stage 4)
BSCSCAN_API_KEY=your_bscscan_api_key_here

# USDT BEP-20 contract on BNB chain
USDT_CONTRACT=0x55d398326f99059fF775485246999027B3197955
