{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/"
    },
    {
      "source": "/admin/(.*)",
      "destination": "/"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/verify-donations",
      "schedule": "0 * * * *"
    }
  ]
}
